# ============================================================
# Carnet Digital CUC - Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Aplicación
NODE_ENV=development
PORT=3000
APP_NAME=carnet-digital-cuc
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# Base de Datos MySQL
DATABASE_URL="mysql://root:password@localhost:3306/carnet_digital_cuc"
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sa12345
DB_NAME=carnet_digital_cuc

# JWT - Access Token
# IMPORTANTE: Cambia estos valores en producción (mínimo 32 caracteres)
JWT_SECRET=carnet_cuc_jwt_super_secreto_2024_minimo_32_chars!!
JWT_EXPIRES_IN=5m

# JWT - Refresh Token
JWT_REFRESH_SECRET=carnet_cuc_refresh_super_secreto_2024_minimo_32!!
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10
