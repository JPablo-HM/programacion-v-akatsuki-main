# ============================================================
# Carnet Digital CUC — .gitignore
# ============================================================

# Compiled output
/dist
/build

# Dependencies
/node_modules
/.pnp
.pnp.js

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db

# Tests
/coverage
/.nyc_output

# IDE / Editors
/.idea
/.vscode
!.vscode/settings.json
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Prisma migrations (generadas automáticamente)
prisma/migrations/

# Prisma client generado
node_modules/.prisma/

# Build info
tsconfig.tsbuildinfo
